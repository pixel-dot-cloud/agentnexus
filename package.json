{
  "name": "agentnexus",
  "version": "1.0.0",
  "description": "AgentNexus — Telegram LLM agent",
  "type": "module",
  "main": "dist/index.js",
  "bin": { "agentnexus": "./bin/agentnexus" },
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "tsc && cp -r src/prompts dist/prompts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.50.0",
    "diff": "^9.0.0",
    "grammy": "^1.36.1",
    "node-fetch": "^2.6.7",
    "strip-ansi": "^7.2.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.4",
    "zx": "^8.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.13",
    "@types/ws": "^8.18.1",
    "typescript": "^5.0.0"
  }
}
